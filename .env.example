# =============================================================================
# OpenBridge — environment configuration
# A Rafiki-based Open Payments account provider.
# Built for the Interledger Open Payments Accelerator 2026.
#
# Copy this file to `.env` and fill in real values. Never commit `.env`.
# =============================================================================

# -----------------------------------------------------------------------------
# Wallet address / ASE identity
# -----------------------------------------------------------------------------
# Host that wallet addresses live under. A wallet address $openbridge.org/marvy
# resolves to https://openbridge.org/marvy. Locally, point this at a public
# tunnel (e.g. ngrok/cloudflared) so external Open Payments clients can reach it.
OPENBRIDGE_DOMAIN=openbridge.org

# Public base URL of the Open Payments resource server (where wallet addresses
# and payment/quote resources are served from).
OPENBRIDGE_PUBLIC_URL=https://openbridge.org

# -----------------------------------------------------------------------------
# Rafiki (ASE core)
# -----------------------------------------------------------------------------
# Rafiki Backend Admin (GraphQL) API — used by the gateway to create wallet
# addresses, peers, quotes and payments.
RAFIKI_BACKEND_URL=http://localhost:3001/graphql

# Rafiki Open Payments resource server (incoming-payments, outgoing-payments,
# quotes).
RAFIKI_RESOURCE_URL=http://localhost:3000

# Rafiki GNAP authorization server (grant request + interaction).
RAFIKI_AUTH_URL=http://localhost:3006

# Shared secret for authenticating gateway -> Rafiki Backend Admin API calls.
RAFIKI_ADMIN_API_SECRET=changeme-admin-secret

# Signature key id + private key (Ed25519) used to sign Open Payments requests.
RAFIKI_KEY_ID=openbridge-key-1
RAFIKI_PRIVATE_KEY_PATH=./secrets/private.key

# -----------------------------------------------------------------------------
# Datastores
# -----------------------------------------------------------------------------
# PostgreSQL — OpenBridge application data: users, corridor mappings,
# ZK commitment records. (Rafiki uses its own databases; see docker-compose.yml.)
DATABASE_URL=postgres://openbridge:openbridge@localhost:5432/openbridge

# Redis — GNAP grant caching, interaction sessions, rate limiting.
REDIS_URL=redis://localhost:6379

# -----------------------------------------------------------------------------
# Corridor feature flags — enable/disable corridors at runtime
# -----------------------------------------------------------------------------
ENABLE_NIGERIA=true
ENABLE_UK=true
ENABLE_US=true

# -----------------------------------------------------------------------------
# Corridor 1 — Nigeria (Paystack / NUBAN / NIBSS)
# -----------------------------------------------------------------------------
# Paystack secret key (use a sk_test_... key against the Paystack sandbox).
PAYSTACK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Base URL for the Paystack API (override only for mocking/testing).
PAYSTACK_BASE_URL=https://api.paystack.co

# -----------------------------------------------------------------------------
# Corridors 2 & 3 — UK (Faster Payments) & US (ACH) via Stripe Connect
# -----------------------------------------------------------------------------
# Stripe secret key (use a sk_test_... key against Stripe test mode).
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Stripe Connect client id (ca_...) for Express account onboarding.
STRIPE_CONNECT_CLIENT_ID=ca_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Stripe webhook signing secret (whsec_...) for verifying payout/charge events.
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# -----------------------------------------------------------------------------
# Zero-knowledge account linkage (Noir / UltraHonk)
# -----------------------------------------------------------------------------
# Path to the UltraHonk verification key produced by `npm run zk:build`.
ZK_VERIFIER_KEY_PATH=./packages/zk-linkage/target/vk

# Path to the compiled Noir circuit artifact (ACIR/bytecode).
ZK_CIRCUIT_PATH=./packages/zk-linkage/target/account_linkage.json

# -----------------------------------------------------------------------------
# Gateway API
# -----------------------------------------------------------------------------
# Port the OpenBridge gateway API listens on.
GATEWAY_PORT=4000

# Runtime environment: development | test | production
NODE_ENV=development
